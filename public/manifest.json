{
	"manifest_version": 3,
	"name": "Blossom",
	"$schema": "https://json.schemastore.org/chrome-manifest.json",
	"version": "0.1.0",
	"description": "A beautiful focused garden for your productivity. Plant trees and grow your forest while staying away from distractions.",
	"icons": {
		"16": "icons/icon_16.png",
		"32": "icons/icon_32.png",
		"48": "icons/icon_48.png",
		"128": "icons/icon_128.png"
	},
	"background": {
		"service_worker": "background.js"
	},
	"action": {
		"default_title": "Blossom",
		"default_popup": "popup.html"
	},
	"permissions": [
		"storage"
	],
	"content_scripts": [
		{
			"matches": [
				"<all_urls>"
			],
			"run_at": "document_idle",
			"js": [
				"contentScript.js"
			]
		}
	]
}